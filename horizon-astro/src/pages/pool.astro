---
// The Pool page — the shared centerpiece all six houses gather around.
// Image-led, brand-consistent (reuses split sections, checks, gallery).
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SplitSection from '../components/SplitSection.astro';
---

<Base
  title="The pool — Horizon Villas Tinos"
  description="One shared pool above Agios Ioannis, at the heart of Horizon Villas — where all six houses meet, from morning coffee to sunset drinks."
>
  <Nav />

  <!-- ============ HEADER ============ -->
  <section class="section tight center">
    <div class="container">
      <p class="eyebrow">The pool</p>
      <h1 style="font-size:clamp(32px,4vw,52px); margin-bottom:16px;">The heart of it</h1>
      <p class="lead">One pool, shared by all six houses, on a quiet hillside above Agios Ioannis. It's where the day begins and ends at Horizon.</p>
    </div>
  </section>

  <!-- ============ BANNER IMAGE ============ -->
  <section style="padding:0;">
    <div class="container">
      <!-- TODO: swap for the pool's <picture> (dusk, wide crop) -->
      <div class="photo media">[ the shared pool at dusk ]</div>
    </div>
  </section>

  <!-- ============ MORNINGS ============ -->
  <SplitSection eyebrow="Mornings" heading="Coffee, and a quiet swim" photoLabel="[ the pool in the morning ]">
    <p>The early hours belong to whoever is up first — a coffee on the terrace, a lap or two before the heat, the island still waking up below.</p>
  </SplitSection>

  <!-- ============ EVENINGS ============ -->
  <SplitSection flip eyebrow="Evenings" heading="A drink as the sun drops" photoLabel="[ the pool at sunset ]" photoBg="#D2BF9F">
    <p>Later, the pool is for the grown-ups — a drink in hand as the sun slips behind the hills and the water turns gold. The one place all six houses share.</p>
  </SplitSection>

  <!-- ============ AROUND THE POOL ============ -->
  <section class="section tight reveal">
    <div class="container">
      <p class="eyebrow">Around the pool</p>
      <div class="checks">
        <span><i class="ti ti-check"></i>Sun loungers &amp; parasols</span>
        <span><i class="ti ti-check"></i>Shaded terrace</span>
        <span><i class="ti ti-check"></i>Outdoor shower</span>
        <span><i class="ti ti-check"></i>Towels provided</span>
        <span><i class="ti ti-check"></i>Steps from every house</span>
        <span><i class="ti ti-check"></i>Open through the season</span>
      </div>
    </div>
  </section>

  <!-- ============ GALLERY ============ -->
  <section class="section tight center reveal">
    <div class="container">
      <p class="eyebrow">More of the pool</p>
      <div class="gallery">
        <div class="photo"></div>
        <div class="photo" style="background:#DFD0B3;"></div>
        <div class="photo" style="background:#DACAAD;"></div>
        <div class="photo cap-tr" style="background:#D5C3A2;">+6</div>
      </div>
    </div>
  </section>

  <!-- ============ CLOSE ============ -->
  <section class="section tight band-dark center reveal">
    <div class="container">
      <h2 style="font-size:clamp(22px,2.4vw,28px); color:#D9A969; margin-bottom:18px;">Your spot by the water is waiting</h2>
      <a class="btn btn-primary" href="/#book" style="margin-right:10px;">Check availability</a>
      <a class="btn btn-outline-light" href="/accommodations">See the houses</a>
    </div>
  </section>

  <Footer id="contact" />
</Base>
