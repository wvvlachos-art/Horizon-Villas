---
// Blog index — editorial story grid (Belmond "Stories" pattern), brand-adapted.
// Centred intro header → topic filter → photography-led card grid.
// (Kept low-key in the nav for now; it'll be sparse for the first few months.)
//
// Data-driven from src/data/articles.ts (Sanity-backed later — see that file).
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { articles, categories } from '../../data/articles';
---

<Base
  title="Blog — Horizon Villas Tinos"
  description="Stories from Horizon Villas and the island of Tinos — the seasons, the food, the walks and the slow days, from the family who live here."
>
  <Nav />

  <!-- ============ PAGE HEADER ============ -->
  <section class="section tight center">
    <div class="container">
      <p class="eyebrow">Blog</p>
      <h1 style="font-size:clamp(32px,4vw,52px); margin-bottom:16px;">Stories from the hillside</h1>
      <p class="lead">Notes on Tinos and life at Horizon — the seasons, the food, the walks and the slow days, written by the family who live here.</p>
    </div>
  </section>

  <!-- ============ TOPIC FILTER ============ -->
  <section class="section tight" style="padding-top:0;">
    <div class="container">
      <div class="filter journal-filter">
        <span class="active" data-filter="all">All</span>
        {categories.map((c) => <span data-filter={c}>{c}</span>)}
      </div>
    </div>
  </section>

  <!-- ============ STORY GRID ============ -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="journal-grid">
        {articles.map((article) => <ArticleCard article={article} />)}
      </div>
    </div>
  </section>

  <Footer id="contact" />
</Base>

<script is:inline>
  // Topic filter: show only cards whose data-category matches (or all).
  const chips = document.querySelectorAll('.journal-filter span');
  const cards = document.querySelectorAll('.journal-grid .acard');
  chips.forEach((chip) =>
    chip.addEventListener('click', () => {
      const f = chip.getAttribute('data-filter');
      chips.forEach((c) => c.classList.toggle('active', c === chip));
      cards.forEach((card) => {
        const show = f === 'all' || card.getAttribute('data-category') === f;
        card.style.display = show ? '' : 'none';
      });
    }),
  );
</script>
