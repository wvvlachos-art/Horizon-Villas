---
// Landing page. Desktop = narrative-first (CLAUDE_NOTES §4):
// hero → the place → the pool → houses preview → Tinos → included →
// book direct → reviews → plan your stay (booking) → footer.
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SplitSection from '../components/SplitSection.astro';
import BookingBar from '../components/BookingBar.astro';
import { houses } from '../data/houses';
---

<Base
  title="Horizon Villas Tinos — six houses, one pool, above the Aegean"
  description="A small family-run collection of six modern houses around one shared pool, above Agios Ioannis on Tinos. Daily cleaning, minutes from the beach — the quiet side of the Cyclades."
>
  <Nav />

  <!-- ============ HERO ============ -->
  <section class="hero">
    <!-- TODO: swap .photo for a <picture> with art-directed desktop + portrait mobile crops -->
    <!-- TRUST SIGNALS: replace placeholder scores with live ratings (wire via Sanity/manual later) -->
    <div class="hero-trust">
      <div class="trust-badge"><span class="src">Booking.com</span><span class="score">9.4</span></div>
      <div class="trust-badge"><span class="src">Airbnb</span><span class="score">4.9<span class="star">★</span></span></div>
      <div class="trust-badge"><span class="src">Google</span><span class="score">4.8<span class="star">★</span></span></div>
    </div>
    <p class="eyebrow">Agios Ioannis · Tinos</p>
    <h1>Six houses, one pool, above the Aegean</h1>
    <a class="btn btn-outline" href="#book">Check availability</a>
    <span class="photo-note">[ full-screen cinematic hero — the pool &amp; houses at dusk ]</span>
  </section>

  <!-- ============ THE PLACE (intro narrative) ============ -->
  <section class="section center reveal">
    <div class="container">
      <p class="eyebrow">The place</p>
      <h2 style="font-size:clamp(30px,3.2vw,44px); margin-bottom:20px;">The quiet side of the Cyclades</h2>
      <p class="lead">Horizon is a small collection of six modern houses, gathered by our family around one shared pool on a quiet hillside above Agios Ioannis. Five minutes from the beach, a world away from the crowds — the Cyclades at its most unhurried.</p>
    </div>
  </section>

  <!-- ============ THE POOL (its own moment) ============ -->
  <SplitSection id="pool" eyebrow="The pool" heading="The heart of it" photoLabel="[ the shared pool ]">
    <p>Where the day slows down — coffee in the morning, the children in the afternoon, a drink as the sun drops behind the hills. The one place all six houses share.</p>
  </SplitSection>

  <!-- ============ THE HOUSES (carousel preview → index) ============ -->
  <section class="section center reveal">
    <div class="container">
      <p class="eyebrow">The houses</p>
      <h2 style="font-size:clamp(28px,3vw,40px); margin-bottom:6px;">Six houses, one design, from €180</h2>
      <div class="house-carousel">
        <div class="hc-track">
          <button class="hc-arrow l" aria-label="Previous house"><i class="ti ti-chevron-left"></i></button>
          <button class="hc-arrow r" aria-label="Next house"><i class="ti ti-chevron-right"></i></button>
          {houses.map((house, i) => (
            <div class:list={['hc-slide', { active: i === 0 }]}>
              <!-- TODO: swap for the house's <picture> / per-house carousel images -->
              <div class="hc-photo" style={house.photoBg ? `background:${house.photoBg};` : undefined}>[ photo ]</div>
              <div class="hc-info">
                <h3>{house.name}</h3>
                <p class="hc-facts">Sleeps {house.sleeps} · {house.view.replace(' view', '')} · {house.size}</p>
                <p>{house.blurb}</p>
                <p class="hc-price">from €{house.priceFrom} <span>/ night</span></p>
                <a class="btn btn-primary btn-sm" href={`/${house.slug}`}>View house</a>
              </div>
            </div>
          ))}
        </div>
        <div class="hc-dots">
          {houses.map((_, i) => <span class:list={[{ active: i === 0 }]} role="button" aria-label={`Show house ${i + 1}`}></span>)}
        </div>
      </div>
      <p style="margin-top:30px;"><a class="link amber" href="/accommodations">See all six houses</a></p>
    </div>
  </section>

  <!-- ============ TINOS (full establishing section) ============ -->
  <SplitSection id="tinos" flip eyebrow="The island" heading="The Cyclades, quietly" photoLabel="[ a Tinos village ]" photoBg="#D2BF9F">
    <p>Marble villages and dovecotes, a serious food scene, footpaths over the hills, and beaches you can still have to yourself. Tinos rewards the traveller who skips Mykonos — never more so than in spring and autumn.</p>
    <p style="margin-top:18px;"><a class="link amber" href="#">Explore Tinos</a></p>
  </SplitSection>

  <!-- ============ THE LOCAL AREA (around Agios Ioannis) ============ -->
  <section class="section center reveal">
    <div class="container">
      <p class="eyebrow">The local area</p>
      <h2 style="font-size:clamp(28px,3vw,40px); margin-bottom:14px;">Five minutes from the good stuff</h2>
      <p class="lead" style="margin-bottom:6px;">Agios Ioannis keeps everything close — the water, a few good tavernas, and the rest of the island just up the road.</p>
      <div class="local">
        <div><h4>Agios Ioannis beach</h4><p>A five-minute walk down to a quiet swimming cove and a beach taverna.</p></div>
        <div><h4>Eat &amp; shop</h4><p>Family tavernas, a bakery and a small market within the village.</p></div>
        <div><h4>Tinos Town &amp; port</h4><p>The harbour, ferries and the main shops, about fifteen minutes by car.</p></div>
        <div><h4>Villages &amp; trails</h4><p>Marble villages, dovecotes and footpaths over the hills to explore.</p></div>
      </div>
    </div>
  </section>

  <!-- ============ INCLUDED (dark band) ============ -->
  <section class="section tight band-dark center reveal">
    <div class="container">
      <p class="eyebrow" style="color:#D9A969;">Included in every stay</p>
      <p style="color:var(--beige); font-size:15px; margin:0;">Daily cleaning&nbsp;&nbsp;·&nbsp;&nbsp;Fresh linens&nbsp;&nbsp;·&nbsp;&nbsp;Fast wifi&nbsp;&nbsp;·&nbsp;&nbsp;Free parking&nbsp;&nbsp;·&nbsp;&nbsp;Welcome basket</p>
    </div>
  </section>

  <!-- ============ BOOK DIRECT ============ -->
  <section id="offers" class="section tight center reveal">
    <div class="container">
      <h2 style="font-size:clamp(28px,3vw,40px); margin-bottom:18px;">Book direct, book better</h2>
      <div style="display:flex; justify-content:center; gap:36px; flex-wrap:wrap; font-size:15px; color:var(--text);">
        <span>Best rate, no commission</span><span>Talk to the family directly</span><span>Flexible dates</span><span>Secure payment</span>
      </div>
    </div>
  </section>

  <!-- ============ REVIEWS ============ -->
  <section class="section tight reveal" style="padding-top:0;">
    <div class="container cards">
      <div class="card" style="padding:18px 20px;">
        <div style="color:var(--amber); font-size:13px; margin-bottom:6px;"><i class="ti ti-star"></i> <i class="ti ti-star"></i> <i class="ti ti-star"></i> <i class="ti ti-star"></i> <i class="ti ti-star"></i></div>
        <p style="font-size:14px; line-height:1.6; color:var(--ink); font-style:italic; margin:0;">"Quiet, spotless, and the pool was perfect for the kids." <span style="color:var(--muted); font-style:normal;">[ sample ]</span></p>
      </div>
      <div class="card" style="padding:18px 20px;">
        <div style="color:var(--amber); font-size:13px; margin-bottom:6px;"><i class="ti ti-star"></i> <i class="ti ti-star"></i> <i class="ti ti-star"></i> <i class="ti ti-star"></i> <i class="ti ti-star"></i></div>
        <p style="font-size:14px; line-height:1.6; color:var(--ink); font-style:italic; margin:0;">"Booking direct was easy and they replied on WhatsApp in minutes." <span style="color:var(--muted); font-style:normal;">[ sample ]</span></p>
      </div>
    </div>
  </section>

  <!-- ============ PLAN YOUR STAY (booking — Lodgify search widget mounts here) ============ -->
  <section id="book" class="section band-beige center reveal">
    <div class="container">
      <h2 style="font-size:clamp(28px,3vw,40px); margin-bottom:10px;">Plan your stay</h2>
      <p style="color:var(--text); margin:0 0 30px;">Check dates and rates across all six houses — book direct for the best price.</p>
      <BookingBar />
    </div>
  </section>

  <Footer id="contact" showEmail />
</Base>

<script is:inline>
  // Houses carousel: arrows + dots swap the active house slide.
  const car = document.querySelector('.house-carousel');
  if (car) {
    const slides = Array.from(car.querySelectorAll('.hc-slide'));
    const dots = Array.from(car.querySelectorAll('.hc-dots span'));
    let i = 0;
    const show = (n) => {
      i = (n + slides.length) % slides.length;
      slides.forEach((s, k) => s.classList.toggle('active', k === i));
      dots.forEach((d, k) => d.classList.toggle('active', k === i));
    };
    car.querySelector('.hc-arrow.l').addEventListener('click', () => show(i - 1));
    car.querySelector('.hc-arrow.r').addEventListener('click', () => show(i + 1));
    dots.forEach((d, k) => d.addEventListener('click', () => show(k)));
  }
</script>
