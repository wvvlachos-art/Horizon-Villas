---
// House detail template (Villa Zoe) — Canaves suite design language:
// full-screen hero with transparent→solid nav, a floating booking card, a
// description+facts row, grouped "what's included" lists beside an interior
// photo, and a note. (CLAUDE_NOTES §4.)
//
// For now this is a single static house. When Sanity / per-house routing lands,
// this becomes a dynamic [slug].astro driven by the houses collection.
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StickyBookingBar from '../components/StickyBookingBar.astro';
import HouseCard from '../components/HouseCard.astro';
import { site } from '../data/site';
import { houses } from '../data/houses';

// Cross-sell: the next three houses after Villa Zoe.
const others = houses.slice(1, 4);
---

<Base
  title="Villa Zoe — Horizon Villas Tinos"
  description="Villa Zoe at Horizon Villas: a bright two-bedroom house opening onto the shared pool, with sea views, on Tinos. Sleeps 4, from €180/night."
>
  <Nav variant="house" />

  <!-- ============ FULL-SCREEN HERO GALLERY ============ -->
  <!-- TODO: swap the background for the house gallery slider; arrows cycle photos -->
  <section class="house-hero">
    <span class="arrow l"><i class="ti ti-chevron-left"></i></span>
    <span class="arrow r"><i class="ti ti-chevron-right"></i></span>
    <span class="count">[ house gallery — 1 / 9 ]</span>
    <div class="hero-caption">
      <p class="eyebrow" style="color:#EBCFA6;">Horizon · House</p>
      <h1>Villa Zoe</h1>
      <p class="sub">A bright two-bedroom opening onto the shared pool</p>
    </div>
  </section>

  <!-- ============ FLOATING BOOKING BAR (Lodgify booking box mounts here) ============ -->
  <StickyBookingBar houseName="Villa Zoe" />

  <!-- ============ DESCRIPTION + FACTS ============ -->
  <section class="section reveal">
    <div class="container">
      <div class="detail-intro">
        <div>
          <div class="k">The house</div>
          <p>The brightest of the six, Villa Zoe opens straight onto the shared pool terrace, with the Aegean filling its windows. Two bedrooms, a full kitchen, and a shaded outdoor table made for long, slow dinners.</p>
        </div>
        <div><div class="k">Sleeps</div><div class="v">4</div></div>
        <div><div class="k">Bedrooms</div><div class="v">2</div></div>
        <div><div class="k">View</div><div class="v">Sea</div></div>
        <div><div class="k">From</div><div class="v price">€180</div></div>
      </div>
    </div>
  </section>

  <!-- ============ WHAT'S INCLUDED (grouped) + PHOTO ============ -->
  <section class="section band-beige reveal">
    <div class="container">
      <p class="eyebrow on-beige">What's included</p>
      <div class="detail-amen">
        <div>
          <div class="grp">
            <h4 class="grp-title">In the house</h4>
            <ul><li>Full kitchen</li><li>Coffee machine</li><li>Fast wifi</li><li>Air-conditioning</li><li>Smart TV</li><li>Hairdryer</li></ul>
          </div>
          <div class="grp">
            <h4 class="grp-title">Comfort &amp; service</h4>
            <ul><li>Daily cleaning</li><li>Fresh linens &amp; towels</li><li>Welcome basket on arrival</li><li>Free parking</li></ul>
          </div>
        </div>
        <div>
          <div class="grp">
            <h4 class="grp-title">Pool &amp; outdoors</h4>
            <ul><li>Access to the shared pool</li><li>Sun loungers</li><li>Shaded private terrace</li><li>Outdoor dining table</li></ul>
          </div>
          <div class="grp">
            <h4 class="grp-title">Good to know</h4>
            <ul><li>Check-in from 3:00 pm</li><li>Check-out by 11:00 am</li><li>Sleeps up to 4</li><li>Five minutes to the beach</li></ul>
          </div>
        </div>
        <div class="photo">[ interior / terrace photo ]</div>
      </div>
    </div>
  </section>

  <!-- ============ A NOTE ============ -->
  <section class="section tight reveal">
    <div class="container">
      <div class="note-block">
        <p class="eyebrow">A note</p>
        <p>The six houses share one design and one pool, so the feel carries across all of them. Photos are representative of Villa Zoe and small details may vary. For anything specific — a travel cot, an earlier check-in, help with the ferry — message us on WhatsApp and we'll arrange it before you arrive.</p>
      </div>
    </div>
  </section>

  <!-- ============ THE OTHER HOUSES ============ -->
  <section class="section tight band-beige reveal">
    <div class="container">
      <p class="eyebrow on-beige center">The other houses</p>
      <div class="cards">
        {others.map((house) => <HouseCard house={house} />)}
      </div>
    </div>
  </section>

  <!-- ============ CLOSE ============ -->
  <section class="section tight band-dark center reveal">
    <div class="container">
      <h2 style="font-size:clamp(20px,2.2vw,26px); color:#D9A969; margin-bottom:18px;">Stay at Villa Zoe</h2>
      <a class="btn btn-primary" href="#book" style="margin-right:10px;">Check availability</a>
      <a class="btn btn-outline-light" href={site.whatsapp}><i class="ti ti-message-circle"></i> WhatsApp</a>
    </div>
  </section>

  <Footer />
</Base>

<script is:inline>
  // Transparent hero nav → solidifies once you scroll past most of the hero.
  const hdr = document.getElementById('siteHeader');
  if (hdr) {
    const onScroll = () => hdr.classList.toggle('solid', window.scrollY > window.innerHeight * 0.7);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
