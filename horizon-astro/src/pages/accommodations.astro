---
// All-houses index. Canaves 3-column listing rows (CLAUDE_NOTES §4), each row
// data-driven from src/data/houses.ts with per-row Description / Highlights /
// Amenities tabs.
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HouseRow from '../components/HouseRow.astro';
import { site } from '../data/site';
import { houses } from '../data/houses';
---

<Base
  title="The houses — Horizon Villas Tinos"
  description="Six modern houses sharing one pool and one hillside above Agios Ioannis on Tinos — in sizes for couples and families alike."
>
  <Nav />

  <!-- ============ PAGE HEADER ============ -->
  <section class="section tight center">
    <div class="container">
      <p class="eyebrow">Accommodations</p>
      <h1 style="font-size:clamp(30px,3.6vw,44px); margin-bottom:16px;">The six houses</h1>
      <p class="lead" style="font-size:clamp(18px,1.9vw,21px);">Six modern houses sharing one pool and one hillside above Agios Ioannis — the same design language throughout, in sizes for couples and families alike.</p>
      <!-- TODO: wire the capacity filter (adaptation of Canaves's tier-tabs) -->
      <div class="filter">
        <span class="active">All</span><span>For couples</span><span>For families</span>
      </div>
    </div>
  </section>

  <!-- ============ LISTING (all six, uniform — Canaves 3-column: image · body · facts) ============ -->
  <section class="section" style="padding-top:8px;">
    <div class="container listing">
      {houses.map((house) => <HouseRow house={house} />)}
    </div>
  </section>

  <!-- ============ HELP / BOOKING CLOSE ============ -->
  <section id="book" class="section band-beige center reveal">
    <div class="container">
      <h2 style="font-size:clamp(22px,2.4vw,28px); margin-bottom:14px;">Not sure which house?</h2>
      <p style="margin:0 0 24px; color:var(--text);">Tell us your dates and group — we'll point you to the right one.</p>
      <a class="btn btn-primary" href="#" style="margin-right:10px;">Check availability</a>
      <a class="btn btn-outline" href={site.whatsapp}><i class="ti ti-message-circle"></i> WhatsApp</a>
    </div>
  </section>

  <Footer id="contact" />
</Base>

<script is:inline>
  // Per-row Description / Highlights / Amenities tabs: clicking a tab toggles
  // the active button + matching panel within that row only.
  document.querySelectorAll('.house-row').forEach((row) => {
    const tabs = row.querySelectorAll('.r-tabs button');
    const panels = row.querySelectorAll('.r-panel');
    tabs.forEach((t, i) =>
      t.addEventListener('click', () => {
        tabs.forEach((x) => x.classList.remove('active'));
        panels.forEach((x) => x.classList.remove('active'));
        t.classList.add('active');
        panels[i].classList.add('active');
      }),
    );
  });
</script>
