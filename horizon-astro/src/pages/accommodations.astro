---
// All-houses index. Uniform rows (Canaves listing pattern, CLAUDE_NOTES §4).
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HouseRow from '../components/HouseRow.astro';
import { site } from '../data/site';
import { houses } from '../data/houses';
---

<Base
  title="The houses — Horizon Villas Tinos"
  description="Six modern houses sharing one pool and one hillside above Agios Ioannis on Tinos — in sizes for couples and families alike."
>
  <Nav />

  <!-- ============ PAGE HEADER ============ -->
  <section class="section tight center">
    <div class="container">
      <p class="eyebrow">Accommodations</p>
      <h1 style="font-size:32px; margin-bottom:14px;">The six houses</h1>
      <p class="lead" style="font-size:17px;">Six modern houses sharing one pool and one hillside above Agios Ioannis — the same design language throughout, in sizes for couples and families alike.</p>
      <!-- TODO: wire the capacity filter (adaptation of Canaves's tier-tabs) -->
      <div class="filter">
        <span class="active">All</span><span>For couples</span><span>For families</span>
      </div>
    </div>
  </section>

  <!-- ============ LISTING (all six, uniform) ============ -->
  <section class="section" style="padding-top:8px;">
    <div class="container">
      {houses.map((house) => <HouseRow house={house} />)}
    </div>
  </section>

  <!-- ============ HELP / BOOKING CLOSE ============ -->
  <section id="book" class="section band-beige center reveal">
    <div class="container">
      <h2 style="font-size:24px; margin-bottom:14px;">Not sure which house?</h2>
      <p style="margin:0 0 22px; color:var(--text);">Tell us your dates and group — we'll point you to the right one.</p>
      <a class="btn btn-primary" href="#" style="margin-right:10px;">Check availability</a>
      <a class="btn btn-outline" href={site.whatsapp}><i class="ti ti-message-circle"></i> WhatsApp</a>
    </div>
  </section>

  <Footer id="contact" />
</Base>
