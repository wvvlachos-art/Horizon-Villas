---
// Accommodations listing row — Canaves 3-column pattern: photo · body · facts.
// The body carries per-row Description / Highlights / Amenities tabs whose
// panels are toggled by the inline script on the accommodations page.
//
// Fully data-driven from the House record (see src/data/houses.ts).
import type { House } from '../data/houses';
import { standardAmenities } from '../data/houses';

interface Props {
  house: House;
}
const { house } = Astro.props;

const view = house.view.replace(' view', '');
const amenities = house.amenities ?? standardAmenities;
---

<article class="house-row reveal">
  <div class="photo">
    <span class="arrow l"><i class="ti ti-chevron-left"></i></span>
    <span class="arrow r"><i class="ti ti-chevron-right"></i></span>
    <span class="count">1 / 5</span>
    [ photo ]
  </div>
  <div class="body">
    <h3>{house.name}</h3>
    <div class="r-tabs">
      <button class="active">Description</button>
      <button>Highlights</button>
      <button>Amenities</button>
    </div>
    <div class="r-panel active"><p>{house.description}</p></div>
    <div class="r-panel"><ul>{house.highlights.map((h) => <li>{h}</li>)}</ul></div>
    <div class="r-panel"><ul>{amenities.map((a) => <li>{a}</li>)}</ul></div>
    <div class="r-cta">
      <a class="btn btn-outline btn-sm" href={`/${house.slug}`}>View house</a>
      <a class="btn btn-primary btn-sm" href={`/${house.slug}#book`}>Check dates</a>
    </div>
  </div>
  <div class="r-facts">
    <div>Sleeps<b>{house.sleeps}</b></div>
    <div>View<b>{view}</b></div>
    <div>Size<b>{house.size}</b></div>
    <div>From<b class="price">€{house.priceFrom}</b></div>
  </div>
</article>
