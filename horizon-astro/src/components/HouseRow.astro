---
// Uniform accommodations-index row (photo-left, Canaves listing pattern).
// Facts strip is derived from the House record.
//
// TODO: the "Description · Highlights · Amenities" tabs are a label only for
// now; wire them up when the detail content is in place.
import type { House } from '../data/houses';

interface Props {
  house: House;
}
const { house } = Astro.props;
---

<article class="house-row reveal">
  <div class="photo" style={house.photoBg ? `background:${house.photoBg};` : undefined}>[ photo ]</div>
  <div class="body">
    <h3>{house.name}</h3>
    <div class="tabs">Description · Highlights · Amenities</div>
    <p style="margin:0;">{house.blurb}</p>
    <div class="facts">
      <span>Sleeps {house.sleeps}</span>
      <span>{house.view}</span>
      <span>{house.size}</span>
      <span class="price">from €{house.priceFrom}</span>
    </div>
    <a class="link" href={`/${house.slug}`} style="margin-right:14px;">View house</a><a class="btn btn-primary btn-sm" href={`/${house.slug}#book`}>Check dates</a>
  </div>
</article>
