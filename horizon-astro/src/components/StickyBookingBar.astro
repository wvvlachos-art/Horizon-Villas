---
// Per-house floating booking bar on the detail page — a raised card that
// overlaps the bottom of the full-screen hero.
//
// ===== LODGIFY MOUNT POINT (CLAUDE_NOTES §2) =====
// Replace the static fields below with the Lodgify per-house BOOKING BOX embed
// (scoped to this house). Until then this renders the inert placeholder.
interface Props {
  houseName: string;
}
const { houseName } = Astro.props;
---

<!-- LODGIFY: replace the fields with the per-house Lodgify BOOKING BOX embed -->
<div id="book" class="book-float">
  <div class="bf"><span class="l">House</span><span class="v">{houseName}</span></div>
  <div class="sep"></div>
  <div class="bf"><span class="l">Arrival</span><span class="v muted">Add date</span></div>
  <div class="sep"></div>
  <div class="bf"><span class="l">Departure</span><span class="v muted">Add date</span></div>
  <div class="sep"></div>
  <div class="bf"><span class="l">Guests</span><span class="v muted">2</span></div>
  <a class="btn btn-primary" href="#">Check availability</a>
</div>
