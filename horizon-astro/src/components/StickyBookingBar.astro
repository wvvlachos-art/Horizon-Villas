---
// Per-house sticky booking bar on the detail page.
//
// ===== LODGIFY MOUNT POINT (CLAUDE_NOTES §2) =====
// Replace the static fields below with the Lodgify per-house BOOKING BOX embed
// (scoped to this house). Until then this renders the inert placeholder.
interface Props {
  houseName: string;
}
const { houseName } = Astro.props;
---

<!-- LODGIFY: replace the fields with the per-house Lodgify BOOKING BOX embed -->
<div id="book" style="position:sticky; top:0; z-index:40; background:var(--paper); border-bottom:0.5px solid var(--line);">
  <div class="container" style="display:flex; gap:10px; align-items:center; flex-wrap:wrap; justify-content:center; padding-top:12px; padding-bottom:12px;">
    <span style="font-size:12px; color:var(--muted); margin-right:4px;">{houseName}</span>
    <span class="field" style="border:0.5px solid var(--line-strong); border-radius:var(--radius); padding:9px 12px; font-size:11px; letter-spacing:1px; text-transform:uppercase; color:var(--muted); min-width:110px;">Arrival</span>
    <span class="field" style="border:0.5px solid var(--line-strong); border-radius:var(--radius); padding:9px 12px; font-size:11px; letter-spacing:1px; text-transform:uppercase; color:var(--muted); min-width:110px;">Departure</span>
    <span class="field" style="border:0.5px solid var(--line-strong); border-radius:var(--radius); padding:9px 12px; font-size:11px; letter-spacing:1px; text-transform:uppercase; color:var(--muted); min-width:80px;">Guests</span>
    <a class="btn btn-primary" href="#">Check availability</a>
  </div>
</div>
