---
// Journal card — photography-led, minimal (Belmond pattern): portrait image,
// category eyebrow, title. Used on the index grid and the article "more
// stories" cross-sell. `data-category` drives the index topic filter.
//
// TODO: swap the .photo placeholder for a <picture> with the article's cover.
import type { Article } from '../data/articles';

interface Props {
  article: Article;
}
const { article } = Astro.props;
---

<a class="acard" href={`/blog/${article.slug}`} data-category={article.category}>
  <div class="photo" style={article.photoBg ? `background:${article.photoBg};` : undefined}>[ photo ]</div>
  <p class="cat">{article.category}</p>
  <h3>{article.title}</h3>
  <p class="rt">{article.readMinutes} min read</p>
</a>
