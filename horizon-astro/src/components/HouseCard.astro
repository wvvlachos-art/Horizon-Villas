---
// Compact house card used in the landing preview and the detail cross-sell.
// Renders a .card with a .photo placeholder + name + "Sleeps N · from €X".
//
// TODO: swap the .photo placeholder for a <picture> with real crops (CLAUDE_NOTES §7).
import type { House } from '../data/houses';

interface Props {
  house: House;
}
const { house } = Astro.props;
---

<a class="card" href={`/${house.slug}`}>
  <div class="photo" style={house.photoBg ? `background:${house.photoBg};` : undefined}>[ photo ]</div>
  <div class="meta">
    <h3>{house.name}</h3>
    <div class="price">Sleeps {house.sleeps} · from €{house.priceFrom}</div>
  </div>
</a>
